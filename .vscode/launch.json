{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "boss-ui",
            "type": "debugpy",
            "request": "launch",
            "module": "bzauto.ui",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": { "PYTHONUNBUFFERED": "1" }
        },
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "cwd": "${workspaceFolder}"
        }
    ]
}
