{
  "manifest_version": 3,
  "name": "Boss直聘远程控制",
  "version": "1.1.0",
  "description": "远程控制Boss直聘页面，支持JS执行、元素坐标查询、标签激活",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.zhipin.com/*",
    "https://*.bosszhipin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.zhipin.com/*",
        "https://*.bosszhipin.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
